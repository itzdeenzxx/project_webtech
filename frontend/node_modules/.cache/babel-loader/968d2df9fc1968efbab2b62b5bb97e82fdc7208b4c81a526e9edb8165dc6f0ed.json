{"ast":null,"code":"import axios from \"axios\";\nexport default {\n  name: \"TheRegister\",\n  data() {\n    return {\n      memEmail: null,\n      memName: null,\n      password: null,\n      backendMessage: null\n    };\n  },\n  methods: {\n    async handleSubmit() {\n      let members = {\n        memEmail: this.memEmail,\n        memName: this.memName,\n        password: this.password\n      };\n      try {\n        const response = await axios.post(`http://localhost:3000/members`, members);\n        this.backendMessage = response.data.messageregister;\n      } catch (err) {\n        console.log(err);\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","memEmail","memName","password","backendMessage","methods","handleSubmit","members","response","post","messageregister","err","console","log"],"sources":["D:\\pj\\project_webtech\\frontend\\src\\components\\TheRegister.vue"],"sourcesContent":["<template>\r\n  <div class=\"row d-flex justify-content-center\">\r\n    <div class=\"col-lg-6 col-md-8 col-sm-12\">\r\n      <form @submit.prevent=\"handleSubmit()\">\r\n        <div class=\"container\">\r\n          <div class=\"heading\">SignIn to your account</div>\r\n          <div class=\"input-field\">\r\n            <input\r\n              type=\"text\"\r\n              class=\"form-control\"\r\n              id=\"memEmail\"\r\n              autocomplete=\"off\"\r\n              required\r\n              placeholder=\"Email\"\r\n              v-model.trim=\"memEmail\"\r\n            />\r\n            <label for=\"memEmail\">Email</label>\r\n          </div>\r\n          <div class=\"input-field\">\r\n            <div class=\"form-floating mb-3\">\r\n              <input\r\n                type=\"text\"\r\n                class=\"form-control\"\r\n                id=\"memName\"\r\n                autocomplete=\"off\"\r\n                required\r\n                placeholder=\"Name\"\r\n                v-model.trim=\"memName\"\r\n              />\r\n              <label for=\"memName\">Name</label>\r\n            </div>\r\n          </div>\r\n          <div class=\"col-lg-12 mb-3\">\r\n            <div class=\"form-floating mb-3\">\r\n              <input\r\n                type=\"password\"\r\n                class=\"form-control\"\r\n                id=\"password\"\r\n                autocomplete=\"off\"\r\n                required\r\n                placeholder=\"Password\"\r\n                v-model.trim=\"password\"\r\n              />\r\n              <label for=\"password\">Password</label>\r\n            </div>\r\n          </div>\r\n          <div class=\"col-sm-12\">\r\n            <button class=\"btn btn-primary float-end\" type=\"submit\">\r\n              <i class=\"bi bi-check-lg\"></i>&nbsp;ตกลง\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </form>\r\n      <!-- ส่วนแสดงสถานะ จากการตอบกลับของ Backend -->\r\n      <p v-if=\"backendMessage == 'success'\" class=\"alert alert-success mt-3\">\r\n        ลงทะเบียนสำเร็จ-{{ backendMessage }}\r\n      </p>\r\n      <p v-else-if=\"backendMessage == 'fail'\" class=\"alert alert-danger mt-3\">\r\n        ลงทะเบียนผิดพลาด-{{ backendMessage }}\r\n      </p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\nexport default {\r\n  name: \"TheRegister\",\r\n  data() {\r\n    return {\r\n      memEmail: null,\r\n      memName: null,\r\n      password: null,\r\n      backendMessage: null,\r\n    };\r\n  },\r\n  methods: {\r\n    async handleSubmit() {\r\n      let members = {\r\n        memEmail: this.memEmail,\r\n        memName: this.memName,\r\n        password: this.password,\r\n      };\r\n      try {\r\n        const response = await axios.post(\r\n          `http://localhost:3000/members`,\r\n          members\r\n        );\r\n        this.backendMessage = response.data.messageregister;\r\n      } catch (err) {\r\n        console.log(err);\r\n      }\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.card {\r\n  background-color: #fffdfd;\r\n}\r\n.card-body {\r\n  padding: 2rem;\r\n}\r\n.card-title {\r\n  font-size: 1.5rem;\r\n  font-weight: 500;\r\n}\r\n.form-floating > input::placeholder {\r\n  color: #6c757d;\r\n}\r\n.btn-primary {\r\n  background-color: #007bff;\r\n  border: none;\r\n}\r\n.btn-primary:hover {\r\n  background-color: #0056b3;\r\n}\r\n.alert {\r\n  font-size: 0.875rem;\r\n}\r\n</style>"],"mappings":"AAiEA,OAAOA,KAAI,MAAO,OAAO;AACzB,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,IAAI;MACdC,OAAO,EAAE,IAAI;MACbC,QAAQ,EAAE,IAAI;MACdC,cAAc,EAAE;IAClB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,YAAYA,CAAA,EAAG;MACnB,IAAIC,OAAM,GAAI;QACZN,QAAQ,EAAE,IAAI,CAACA,QAAQ;QACvBC,OAAO,EAAE,IAAI,CAACA,OAAO;QACrBC,QAAQ,EAAE,IAAI,CAACA;MACjB,CAAC;MACD,IAAI;QACF,MAAMK,QAAO,GAAI,MAAMV,KAAK,CAACW,IAAI,CAC/B,+BAA+B,EAC/BF,OACF,CAAC;QACD,IAAI,CAACH,cAAa,GAAII,QAAQ,CAACR,IAAI,CAACU,eAAe;MACrD,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,GAAG,CAACF,GAAG,CAAC;MAClB;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}